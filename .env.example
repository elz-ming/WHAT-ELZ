# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# MCP auth — shared PAT wrapped by OAuth (generate with: openssl rand -hex 32)
MCP_TOKEN=your-mcp-token

# Optional: override origin used in OAuth discovery metadata
# NEXT_PUBLIC_MCP_BASE_URL=https://your-website.com

# Clerk — admin page auth (get from dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-publishable-key
CLERK_SECRET_KEY=sk_test_your-secret-key

# AI — Groq for fast inference (get from console.groq.com)
GROQ_API_KEY=gsk_your-groq-api-key

# Email delivery — Resend (get from resend.com/api-keys)
RESEND_API_KEY=re_your-resend-api-key

# Anthropic — Claude API (get from console.anthropic.com → API keys)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Inngest — background functions & crons (get from app.inngest.com)
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=signkey-prod-your-inngest-signing-key

# Gmail OAuth — job email sync (run scripts/get-gmail-token.ts to obtain refresh token)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REFRESH_TOKEN=your-google-refresh-token
